{
  "name": "@crew/claudefn",
  "version": "0.2.0",
  "private": false,
  "description": "Claude as a function — call Claude Code CLI programmatically with types and composition",
  "license": "MIT",
  "author": "Crew Framework Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/crew-framework/crew.git",
    "directory": "packages/claudefn"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "vitest": "^3.1.0",
    "@types/node": "^22.0.0"
  }
}
